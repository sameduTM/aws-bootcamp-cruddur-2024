{
    "family": "backend-flask",
    "executionRoleArn": "arn:aws:iam::136140697286:role/CruddurServiceExecutionRole",
    "taskRoleArn": "arn:aws:iam::136140697286:role/CruddurTaskRole",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "containerDefinitions": [
        {
            "name": "backend-flask",
            "image": "136140697286.dkr.ecr.ca-central-1.amazonaws.com/backend-flask",
            "cpu": 256,
            "memory": 512,
            "essential": true,
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "python /backend-flask/bin/flask/health-check || exit 1"
                ],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            },
            "portMappings": [
                {
                    "name": "backend-flask",
                    "containerPort": 4567,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "cruddur",
                    "awslogs-region": "ca-central-1",
                    "awslogs-stream-prefix": "backend-flask"
                }
            },
            "environment": [
                {
                    "name": "OTEL_SERVICE_NAME",
                    "value": "backend-flask"
                },
                {
                    "name": "OTEL_EXPORTER_OTLP_ENDPOINT",
                    "value": "https://api.honeycomb.io"
                },
                {
                    "name": "AWS_COGNITO_USER_POOL_ID",
                    "value": "ca-central-1_HXjic6wve"
                },
                {
                    "name": "AWS_COGNITO_USER_POOL_CLIENT_ID",
                    "value": "4tlq19fpupkjr2c2ecmkqgts72"
                },
                {
                    "name": "FRONTEND_URL",
                    "value": "*"
                },
                {
                    "name": "BACKEND_URL",
                    "value": "*"
                },
                {
                    "name": "AWS_DEFAULT_REGION",
                    "value": "ca-central-1"
                }
            ],
            "secrets": [
                {
                    "name": "AWS_ACCESS_KEY_ID",
                    "valueFrom": "arn:aws:ssm:ca-central-1:136140697286:parameter/cruddur/backend-flask/AWS_ACCESS_KEY_ID"
                },
                {
                    "name": "AWS_SECRET_ACCESS_KEY",
                    "valueFrom": "arn:aws:ssm:ca-central-1:136140697286:parameter/cruddur/backend-flask/AWS_SECRET_ACCESS_KEY"
                },
                {
                    "name": "CONNECTION_URL",
                    "valueFrom": "arn:aws:ssm:ca-central-1:136140697286:parameter/cruddur/backend-flask/CONNECTION_URL"
                },
                {
                    "name": "ROLLBAR_ACCESS_TOKEN",
                    "valueFrom": "arn:aws:ssm:ca-central-1:136140697286:parameter/cruddur/backend-flask/ROLLBAR_ACCESS_TOKEN"
                },
                {
                    "name": "OTEL_EXPORTER_OTLP_HEADERS",
                    "valueFrom": "arn:aws:ssm:ca-central-1:136140697286:parameter/cruddur/backend-flask/OTEL_EXPORTER_OTLP_HEADERS"
                }
            ]
        }
    ]
}
