#!/usr/bin/bash
set -e # stop if it fails at any point

CYAN='\033[1;36m'
NO_COLOR='\033[0m'
LABEL="ddb-setup"
printf "${CYAN}==== ${LABEL}${NO_COLOR}\n"

bin_path="$(realpath .)/bin"
backend_path="$(realpath .)/backend-flask"

source "$bin_path/ddb/drop"
source "$backend_path/bin/ddb/schema-load"
source "$backend_path/bin/ddb/seed"