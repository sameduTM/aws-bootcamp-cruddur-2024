#!/usr/bin/bash
set -e

source .env

ABS_PATH=$(readlink -f "$0")
BUILD_PATH=$(dirname $ABS_PATH)
DOCKER_PATH=$(dirname $BUILD_PATH)
BIN_PATH=$(dirname $DOCKER_PATH)
PROJECT_PATH=$(dirname $BIN_PATH)
echo $PROJECT_PATH

FRONTEND_REACT_JS_PATH="$PROJECT_PATH/frontend-react-js"
echo $FRONTEND_REACT_JS_PATH

docker build \
--build-arg REACT_APP_BACKEND_URL="${BACKEND_URL}" \
--build-arg REACT_APP_AWS_PROJECT_REGION="$AWS_DEFAULT_REGION" \
--build-arg REACT_APP_AWS_COGNITO_REGION="$AWS_DEFAULT_REGION" \
--build-arg REACT_APP_AWS_USER_POOLS_ID="${AWS_COGNITO_USER_POOL_ID}" \
--build-arg REACT_APP_CLIENT_ID="${COGNITO_APP_CLIENT_ID}" \
-t frontend-react-js-prod \
-f $FRONTEND_REACT_JS_PATH/Dockerfile.prod \
"$FRONTEND_REACT_JS_PATH/."
