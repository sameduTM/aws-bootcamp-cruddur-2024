#!/usr/bin/env python3
import boto3
import json
import os

user_pool_id = os.getenv("AWS_COGNITO_USER_POOL_ID")
client = boto3.client('cognito-idp')
params = {
    'UserPoolId': user_pool_id,
    'AttributesToGet': [
        'preferred_username'
    ]
}
response = client.list_users(**params)
users = response['Users']

print(json.dumps(users, sort_keys=True, indent=2 ,default=str))

dict_users = {}

for user in users:
    attr = user['Attributes']
    sub = next((a for a in attr if a["Name"] == "sub"), None)
    handle = next((a for a in attr if a["Name"] == "preferred_username"), None)

    dict_users[handle['Value']] = user['Username']

print(dict_users)