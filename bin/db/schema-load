#!/usr/bin/bash
set -e
source .env

CYAN=$'\033[1;36m'
NO_COLOR=$'\033[0m'
LABEL="db-schema-load"
printf "%s==== %s%s\n" "${CYAN}" "${LABEL}" "${NO_COLOR}"

printf "%s\n" "$(curl ifconfig.me -s)"

schema_path=$(realpath .)/backend-flask/bin/db/schema.sql
echo $schema_path

if [ "$1" == "prod" ]; then
    echo "Connecting to production..."
    CON_URL=$PROD_CONNECTION_URL
else
    CON_URL=$CONNECTION_URL
fi

echo "$CON_URL"

psql "$CON_URL" cruddur < "$schema_path"
