#!/usr/bin/bash

CYAN=$'\033[1;36m'
NO_COLOR=$'\033[0m'
LABEL="db-terminate-sessions"
printf "%s==== %s%s\n" "${CYAN}" "${LABEL}" "${NO_COLOR}"

if [ "$1" == "prod" ]; then
    echo "Connecting to production"
    URL=$PROD_CONNECTION_URL
else
    URL=$CONNECTION_URL
fi

NO_DB_URL=$(sed 's/\/cruddur//g' <<<"$URL")
psql "$NO_DB_URL" -c "SELECT pg_terminate_backend(pg_stat_activity.pid) \
FROM pg_stat_activity \
WHERE pg_stat_activity.datname = 'cruddur' \
AND pid <> pg_backend_pid();"

