#!/usr/bin/bash

CYAN=$'\033[1;36m'
NO_COLOR=$'\033[0m'
LABEL="db-sessions"
printf "%s==== %s%s\n" "${CYAN}" "${LABEL}" "${NO_COLOR}"

if [ "$1" == "prod" ]; then
    echo "Connecting to production"
    URL=$PROD_CONNECTION_URL
else
    URL=$CONNECTION_URL
fi

NO_DB_URL=$(sed 's/\/cruddur//g' <<<"$URL")
psql "$NO_DB_URL" -c "select pid as process_id, \
       usename as user,  \
       datname as db, \
       client_addr, \
       application_name as app,\
       state \
from pg_stat_activity;"