#!/usr/bin/bash

CYAN=$'\033[1;36m'
NO_COLOR=$'\033[0m'
LABEL="db-seed"
printf "%s==== %s%s\n" "${CYAN}" "${LABEL}" "${NO_COLOR}"

seed_path=$(realpath .)/db/seed.sql

if [ "$1" == "prod" ]; then
    echo "Connecting to production..."
    CON_URL=$PROD_CONNECTION_URL
else
    CON_URL=$CONNECTION_URL
fi

echo "$CON_URL"

psql "$CON_URL" cruddur < "$seed_path"